# Cursor-only runtime. Leave AI_PROVIDER=cursor or omit it.
AI_PROVIDER=cursor
CURSOR_API_KEY=crsr_your_api_key_here
CURSOR_MODEL=composer-2
CURSOR_CHARACTER_MODEL=composer-2
CURSOR_EMOTION_MODEL=composer-2

# Optional ports
PORT=8787
VITE_PORT=5173

# Optional automation safety overrides
# suggestion_only | approval_required | auto_executable
AUTOMATION_MAX_EXECUTION_LEVEL=auto_executable
# AUTOMATION_ALLOW_IN_APP_AUTO_EXECUTE=true

# Optional live chat integrations
# YouTube / Twitch can start without extra keys in the current implementation.
# Kick mode requires both values below.
KICK_CLIENT_ID=
KICK_CLIENT_SECRET=

# MemKraft storage and runtime
MEMKRAFT_DIR=./memory
# Use "local" only when running the Python worker on the host.
MEMKRAFT_EXECUTION_MODE=container
MEMKRAFT_PYTHON_BIN=python3
MEMKRAFT_AGENT_ID=catlin
MEMKRAFT_CHANNEL_ID=catlin-global
MEMKRAFT_CONTAINER_RUNTIME=podman
MEMKRAFT_CONTAINER_NAME=maid-cat-memkraft
MEMKRAFT_CONTAINER_IMAGE=maid-cat-memkraft:latest
MEMKRAFT_CONTAINER_WORKDIR=/workspace

# VOICEVOX
VOICEVOX_URL=http://127.0.0.1:50021
VOICEVOX_SPEAKER=1
VOICEVOX_CONTAINER_RUNTIME=podman
VOICEVOX_CONTAINER_NAME=maid-cat-voicevox
VOICEVOX_IMAGE=docker.io/voicevox/voicevox_engine:cpu-latest
VOICEVOX_PORT=50021

# Optional Bun + Cursor override for environments where Node is not on PATH.
# NODE_EXECUTABLE=C:\Program Files\nodejs\node.exe
