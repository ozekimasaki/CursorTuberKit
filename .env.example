# Secrets and process-level environment only.
# Normal app settings live in config/defaults.json and config/local.json.
CURSOR_API_KEY=crsr_your_api_key_here

# Optional secret credentials for live chat integrations.
KICK_CLIENT_ID=
KICK_CLIENT_SECRET=

# Optional secret token for MCP discovery endpoints.
MCP_DISCOVERY_TOKEN=

# NODE_ENV is not a secret, but libraries read it before app config loads.
# NODE_ENV=production
