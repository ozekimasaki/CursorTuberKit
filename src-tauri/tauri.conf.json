{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "CursorTuberKit",
  "version": "0.1.0",
  "identifier": "com.cursortuberkitt.app",
  "build": {
    "beforeDevCommand": "npm run dev:client",
    "beforeBuildCommand": "npm run build:client",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist/client"
  },
  "app": {
    "windows": [
      {
        "title": "CursorTuberKit",
        "width": 1280,
        "height": 800,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
